{
  "name": "highcharts-export-server",
  "author": "Highsoft AS <support@highcharts.com> (http://www.highcharts.com/about)",
  "license": "MIT",
  "type": "module",
  "version": "5.1.0",
  "main": "./dist/index.esm.js",
  "repository": {
    "url": "https://github.com/highcharts/node-export-server",
    "type": "git"
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "bin",
    "dist",
    "lib",
    "msg",
    "public",
    "templates"
  ],
  "bin": {
    "highcharts-export-server": "./bin/cli.js"
  },
  "scripts": {
    "prestart": "rm -rf tmp || npx -y rimraf tmp && node ./node_modules/puppeteer/install.mjs",
    "start": "node ./bin/cli.js --enableServer true --logLevel 2",
    "start:dev": "npx -y nodemon ./bin/cli.js --enableServer true --logLevel 4",
    "start:debug": "node --inspect-brk=9229 ./bin/cli.js --enableDebug true --enableServer true --logLevel 4",
    "complete": "npm run lint && npm run format && npm run build",
    "lint": "eslint ./ --ext .js,.ts --fix",
    "format": "prettier ./ --config prettier.config.mjs --write",
    "build": "rollup --config --silent",
    "prepack": "npm run build",
    "unit:test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepare": "husky || true"
  },
  "dependencies": {
    "colors": "^1.4.0",
    "cors": "^2.8.5",
    "dompurify": "^3.2.6",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "https-proxy-agent": "^7.0.6",
    "jsdom": "^26.1.0",
    "multer": "^2.0.1",
    "prompts": "^2.4.2",
    "puppeteer": "^24.12.1",
    "tarn": "^3.0.2",
    "uuid": "^11.1.0",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.1",
    "@eslint/js": "^9.30.1",
    "@jest/globals": "^30.0.4",
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.1",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "lint-staged": "^16.1.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "rollup": "^4.44.2"
  }
}
