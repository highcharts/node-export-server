{
  "name": "highcharts-export-server",
  "author": "Highsoft AS <support@highcharts.com> (http://www.highcharts.com/about)",
  "license": "MIT",
  "type": "module",
  "version": "6.0.0",
  "main": "./dist/index.esm.js",
  "repository": {
    "url": "https://github.com/highcharts/node-export-server",
    "type": "git"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "./bin/",
    "./dist/",
    "./lib/",
    "./msg/",
    "./public/",
    "./templates/"
  ],
  "bin": {
    "highcharts-export-server": "./bin/cli.js"
  },
  "scripts": {
    "prestart": "rm -rf ./tmp || npx -y rimraf ./tmp && node ./node_modules/puppeteer/install.mjs",
    "start": "node ./bin/cli.js --enableServer true --logLevel 2",
    "dev": "npx -y nodemon ./bin/cli.js --enableServer true --logLevel 4",
    "debug": "node --inspect-brk=9229 ./bin/cli.js --enableDebug true --enableServer true --logLevel 4",
    "complete": "npm run format && npm run lint && npm run build & npm run unit:test",
    "format": "prettier ./ --config prettier.config.js --write",
    "lint": "eslint ./ --fix",
    "build": "rollup --config --silent",
    "prepack": "npm run build",
    "unit:test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "prepare": "husky || true"
  },
  "dependencies": {
    "colors": "^1.4.0",
    "cors": "^2.8.5",
    "dompurify": "^3.2.7",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "highcharts": "^12.4.0",
    "https-proxy-agent": "^7.0.6",
    "jsdom": "^27.0.0",
    "multer": "^2.0.2",
    "prompts": "^2.4.2",
    "puppeteer": "^24.23.0",
    "tarn": "^3.0.2",
    "uuid": "^13.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@eslint/config-helpers": "^0.4.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.36.0",
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.3",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "rollup": "^4.52.3"
  }
}
